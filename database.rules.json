{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('players/p1/uid').val() === auth.uid || data.child('players/p2/uid').val() === auth.uid || (!data.child('players/p2').exists() && newData.child('players/p2/uid').val() === auth.uid))"
      }
    },
    "publicRooms": {
      ".read": "auth != null",
      "$groupCode": {
        "$roomId": {
          ".write": "auth != null"
        }
      }
    },
    "playerProgress": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "leaderboards": {
      "solo": {
        ".read": "auth != null",
        ".indexOn": ["attempts", "timestamp"],
        "$entryId": {
          ".write": "auth != null && newData.child('uid').val() === auth.uid && newData.child('attempts').val() >= 1 && newData.child('attempts').val() <= 7",
          ".validate": "newData.hasChildren(['uid', 'displayName', 'attempts', 'timestamp'])"
        }
      },
      "league": {
        ".read": "auth != null",
        ".indexOn": ["highestLevel", "totalWins"],
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['displayName', 'highestLevel', 'totalWins', 'updatedAt'])"
        }
      }
    }
  }
}
